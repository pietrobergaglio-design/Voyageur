# Copy this file to .env and fill in your API keys.
# NEVER commit .env — it is listed in .gitignore.

# Anthropic Claude API — https://console.anthropic.com/
# Used for AI itinerary generation (claude-sonnet-4-6).
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Duffel Flights API — https://app.duffel.com/
# Used for real-time flight search. Use a test-mode key during development.
EXPO_PUBLIC_DUFFEL_API_KEY=

# RapidAPI — https://rapidapi.com/
# Used for Booking.com hotels and Booking.com attractions endpoints.
EXPO_PUBLIC_RAPIDAPI_KEY=

# RapidAPI host for Booking.com (do not change unless using a different plan).
EXPO_PUBLIC_RAPIDAPI_HOST_BOOKING=booking-com15.p.rapidapi.com

# SimpleVisa API — https://simplevisa.com/ (placeholder — not yet active)
EXPO_PUBLIC_SIMPLEVISA_KEY=
